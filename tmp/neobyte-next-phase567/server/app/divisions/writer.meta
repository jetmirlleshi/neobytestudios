{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/divisions/layout,_N_T_/divisions/[slug]/layout,_N_T_/divisions/[slug]/page,_N_T_/divisions/writer"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/divisions/$d$slug/__PAGE__",
    "/divisions/$d$slug",
    "/divisions",
    "/_index",
    "/_head"
  ]
}